datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// --- 1. USER & PERSONALIZATION ---

model User {
  id         String          @id @default(cuid())
  email      String          @unique
  gender     Gender
  age        Int
  createdAt  DateTime        @default(now())
  
  // Link to a Tag (Many users can have one Tag)
  tagId      String?
  tag        Tag?            @relation(fields: [tagId], references: [id])
  
  settings   UserSettings?
  selections UserSelection[]
  
  // Personalized Collections
  userAnalogies UserAnalogy[]
  userKeywords  UserKeyword[]
}

enum Gender {
  MALE
  FEMALE
}

model UserSettings {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  
  // UI preferences & AI config
  config    Json     @default("{\"theme\": \"light\", \"colors\": {}}")
  updatedAt DateTime @updatedAt
}

// --- 2. CONTENT HIERARCHY (The Tree) ---

model Unit {
  id        String       @id @default(cuid())
  title     String
  summary   UnitSummary?
  lessons   Lesson[]
  
  analogies MasterAnalogy[]
  keywords  MasterKeyword[]
  examples  Example[]
  exercises Exercise[]
  tagLinks  TagRelator[]
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  depth     Int      @default(0)
  order     Int      

  parentId  String?
  parent    Lesson?  @relation("SubLessons", fields: [parentId], references: [id])
  children  Lesson[] @relation("SubLessons")
  
  unitId    String?
  unit      Unit?    @relation(fields: [unitId], references: [id])
  
  paragraphs MasterParagraph[]
  analogies  MasterAnalogy[]
  keywords   MasterKeyword[]
  examples   Example[]
  exercises  Exercise[]
  tagLinks   TagRelator[]
}

model MasterParagraph {
  id        String   @id @default(cuid())
  content   String   @db.Text
  order     Int
  isDefault Boolean  @default(true)
  
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  
  boxes         Box[]
  analogies     MasterAnalogy[]
  userAnalogies UserAnalogy[]
  examples      Example[]
  tagLinks      TagRelator[]
  selections    UserSelection[]
}

// --- 3. DYNAMIC LAYOUT & STATIC TOOLS ---

model Box {
  id          String    @id @default(cuid())
  title       String?
  logo        String?   
  content     String    
  paragraphId String
  paragraph   MasterParagraph @relation(fields: [paragraphId], references: [id])
  placement   Placement @default(AFTER)
  order       Int       @default(0)
}

enum Placement {
  BEFORE
  AFTER
}

model MasterKeyword {
  id         String   @id @default(cuid())
  word       String
  definition String   @db.Text
  
  unitId     String?
  unit       Unit?    @relation(fields: [unitId], references: [id])
  lessonId   String?
  lesson     Lesson?  @relation(fields: [lessonId], references: [id])
  
  tagLinks      TagRelator[]
  userKeywords  UserKeyword[]
}

model Example {
  id          String   @id @default(cuid())
  question    Json     
  answer      String   @db.Text
  
  unitId      String?
  unit        Unit?    @relation(fields: [unitId], references: [id])
  lessonId    String?
  lesson      Lesson?  @relation(fields: [lessonId], references: [id])
  paragraphId String?
  paragraph   MasterParagraph? @relation(fields: [paragraphId], references: [id])
}

model Exercise {
  id        String   @id @default(cuid())
  type      String   
  data      Json     
  unitId    String?
  unit      Unit?    @relation(fields: [unitId], references: [id])
  lessonId  String?
  lesson    Lesson?  @relation(fields: [lessonId], references: [id])
}

model UnitSummary {
  id        String @id @default(cuid())
  content   String @db.Text
  unitId    String @unique
  unit      Unit   @relation(fields: [unitId], references: [id])
}

// --- 4. TAGGING & AI COLLECTIONS (The Brain) ---

model Tag {
  id      String       @id @default(cuid())
  name    String       @unique 
  labels  String[] 
  links   TagRelator[]
  users   User[]
}

model TagRelator {
  id          String   @id @default(cuid())
  tagId       String
  tag         Tag      @relation(fields: [tagId], references: [id])
  likes       Int      @default(0)
  dislikes    Int      @default(0)

  unitId      String?
  unit        Unit?            @relation(fields: [unitId], references: [id])
  lessonId    String?
  lesson      Lesson?          @relation(fields: [lessonId], references: [id])
  paragraphId String?
  paragraph   MasterParagraph? @relation(fields: [paragraphId], references: [id])
  analogyId   String?
  analogy     MasterAnalogy?   @relation(fields: [analogyId], references: [id])
  keywordId   String?
  keyword     MasterKeyword?   @relation(fields: [keywordId], references: [id])
}

model MasterAnalogy {
  id          String   @id @default(cuid())
  content     String   @db.Text
  category    String   
  isDefault   Boolean  @default(false)

  unitId      String?
  unit        Unit?            @relation(fields: [unitId], references: [id])
  lessonId    String?
  lesson      Lesson?          @relation(fields: [lessonId], references: [id])
  paragraphId String?
  paragraph   MasterParagraph? @relation(fields: [paragraphId], references: [id])

  tagLinks      TagRelator[]
  selections    UserSelection[]
  userAnalogies UserAnalogy[]
}

// --- NEW: USER COLLECTIONS (The AI "Analogies" and "Keywords") ---

model UserAnalogy {
  id              String   @id @default(cuid())
  content         String   @db.Text
  interestContext String   // The Tag name or label used to generate this
  
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  masterAnalogyId String?
  master          MasterAnalogy? @relation(fields: [masterAnalogyId], references: [id])
  
  paragraphId     String
  paragraph       MasterParagraph @relation(fields: [paragraphId], references: [id])

  createdAt       DateTime @default(now())
  
  @@map("user_analogies")
}

model UserKeyword {
  id              String   @id @default(cuid())
  word            String
  customDefinition String  @db.Text
  
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  masterKeywordId String?
  master          MasterKeyword? @relation(fields: [masterKeywordId], references: [id])

  createdAt       DateTime @default(now())
  
  @@map("user_keywords")
}

model UserSelection {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  
  masterParagraphId String
  paragraph         MasterParagraph @relation(fields: [masterParagraphId], references: [id])
  
  activeAnalogyId   String?
  activeAnalogy     MasterAnalogy?  @relation(fields: [activeAnalogyId], references: [id])

  @@unique([userId, masterParagraphId])
}