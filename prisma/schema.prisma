generator client {
  provider = "prisma-client-js"
   engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum ActionStatus {
  liked
  disliked
  neutral
}

enum Gender {
  MALE
  FEMALE
}
enum Role {
  STUDENT
  ADMIN
}
// --- USER & AUTH ---

model User {
  id              String   @id @default(uuid())
  gender          Gender   // Changed to Enum
  age             Int
  first           String
  last            String
  email           String   @unique
  password        String
  username       String   @unique
  imgUrl          String?
  createdAt       DateTime @default(now())
  userspecificAPI String[]
  role            Role     @default(STUDENT)
  UISettings      Json?

  userTags        UserTag[]
  userAnalogy     UserAnalogy[]
  userParagraph   UserParagraph[]
  userSummery     UserSummery[]
  userKeyWords    UserKeyWords[]
  userNote        UserNote[]
  
  defaultAnalogies  DefaultAnalogy[]
  defaultParagraphs DefaultParagraph[]
  defaultSummaries  DefaultSummery[]
  defaultKeywords   KeyWordDefault[]
  defaultNotes      NoteDefault[]
  notes             Note[]
}

model UserTag {
  id          String @id @default(uuid())
  UserId      String
  TagId       String
  likingLevel Float  @default(0)
  user        User   @relation(fields: [UserId], references: [id])
  tag         Tag    @relation(fields: [TagId], references: [id])
}

// --- EDUCATION HIERARCHY ---

model Book {
  id      String @id @default(uuid())
  subject String
  grade   Int
  imgUrl  String
  units   Unit[]
}

model Unit {
  id        String    @id @default(uuid())
  title     String
  BookId    String
  book      Book      @relation(fields: [BookId], references: [id])
  lessons   Lesson[]
  summeries Summery[]
}

model Lesson {
  id             String   @id @default(uuid())
  title          String
  unitId         String
  ParentLessonId String?
  index          Int
  unit           Unit     @relation(fields: [unitId], references: [id])
  
  analogies      Analogy[]
  paragraphs     Paragraph[]
  keywords       KeyWords[]
  notes          Note[]
  summeries      Summery[]
  realParagraphs RealParagraph[]

  ParentLesson   Lesson?  @relation("SubLessons", fields: [ParentLessonId], references: [id])
  SubLessons     Lesson[] @relation("SubLessons")
}

model RealParagraph {
  id        String   @id @default(uuid())
  content   String
  LessonId  String
  order     Int      @default(0)
  lesson    Lesson   @relation(fields: [LessonId], references: [id])
  analogies Analogy[]
  keywords  KeyWords[]
  
  views     Int      @default(0)
  usage     Int      @default(0)
  flags     Int      @default(0)
  createdAt DateTime @default(now())
}

// --- TAGGING SYSTEM ---

model Tag {
  id          String   @id @default(uuid())
  name        String   @unique
  linkedWith  String[]
  analogies   TagRelatorAnalogy[]
  paragraphs  TagRelatorParagraph[]
  summeries   TagRelatorSummery[]
  keywords    TagRelatorKeyWords[]
  notes       TagRelatorNote[]
  userTags    UserTag[]
  universalTag UniversalTag?
}

model UniversalTag {
  id    String @id @default(uuid())
  tagID String @unique
  tag   Tag    @relation(fields: [tagID], references: [id])
}

// --- CONTENT SYSTEMS ---

model Analogy {
  id               String   @id @default(uuid())
  content          String
  logic            String
  lessonId         String?
  RealParagraphId  String?
  likes            Int      @default(0)
  dislikes         Int      @default(0)
  views            Int      @default(0)
  usage            Int      @default(0)
  flags            Int      @default(0)
  createdAt        DateTime @default(now())
  
  lesson           Lesson?  @relation(fields: [lessonId], references: [id])
  realParagraph    RealParagraph? @relation(fields: [RealParagraphId], references: [id])
  
  activeInSlots    DefaultAnalogy? @relation("ActiveAnalogy")
  parentSlot       DefaultAnalogy? @relation("AnalogyPool", fields: [defaultAnalogyId], references: [id])
  defaultAnalogyId String?

  tagsAnalogy      TagRelatorAnalogy[]
  userActions      UserAnalogy[]
}

model Paragraph {
  id                 String   @id @default(uuid())
  content            String
  LessonId           String
  MasterParagraphId  String   
  likes              Int      @default(0)
  dislikes           Int      @default(0)
  views              Int      @default(0)
  usage              Int      @default(0)
  flags              Int      @default(0)
  createdAt          DateTime @default(now())

  lesson             Lesson   @relation(fields: [LessonId], references: [id])
  
  activeInSlots      DefaultParagraph? @relation("ActiveParagraph")
  parentSlot         DefaultParagraph? @relation("ParagraphPool", fields: [defaultParagraphId], references: [id])
  defaultParagraphId String?

  tagsParagraph      TagRelatorParagraph[]
  userActions        UserParagraph[]
}

model Summery {
  id               String   @id @default(uuid())
  content          String
  LessonId         String?
  UnitId           String?
  likes            Int      @default(0)
  dislikes         Int      @default(0)
  views            Int      @default(0)
  usage            Int      @default(0)
  flags            Int      @default(0)
  createdAt        DateTime @default(now())

  lesson           Lesson?  @relation(fields: [LessonId], references: [id])
  unit             Unit?    @relation(fields: [UnitId], references: [id])
  
  activeInSlots    DefaultSummery? @relation("ActiveSummery")
  parentSlot       DefaultSummery? @relation("SummeryPool", fields: [defaultSummeryId], references: [id])
  defaultSummeryId String?

  tagsSummery      TagRelatorSummery[]
  userActions      UserSummery[]
}

model KeyWords {
  id                String   @id @default(uuid())
  lessonId          String?
  RealParagraphId   String?
  likes             Int      @default(0)
  dislikes          Int      @default(0)
  views             Int      @default(0)
  usage             Int      @default(0)
  flags             Int      @default(0)
  createdAt          DateTime @default(now())

  lesson            Lesson?  @relation(fields: [lessonId], references: [id])
  realParagraph     RealParagraph? @relation(fields: [RealParagraphId], references: [id])
  
  activeInSlots     KeyWordDefault? @relation("ActiveKeywords")
  parentSlot        KeyWordDefault? @relation("KeywordsPool", fields: [defaultKeywordsId], references: [id])
  defaultKeywordsId String?

  tagsKeyWords      TagRelatorKeyWords[]
  userActions       UserKeyWords[]
}

model Note {
  id              String   @id @default(uuid())
  content         String
  UserId          String
  LessonId        String
  likes           Int      @default(0)
  dislikes        Int      @default(0)
  views           Int      @default(0)
  usage           Int      @default(0)
  flags           Int      @default(0)
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [UserId], references: [id])
  lesson          Lesson   @relation(fields: [LessonId], references: [id])
  
  activeInSlots   NoteDefault? @relation("ActiveNote")
  parentSlot      NoteDefault? @relation("NotePool", fields: [defaultNoteId], references: [id])
  defaultNoteId   String?

  tagsNote        TagRelatorNote[]
  userActions     UserNote[]
}

// --- RELATORS ---

model TagRelatorAnalogy {
  id        String  @id @default(uuid())
  TagId     String
  AnalogyId String
  views     Int     @default(0)
  usage     Int     @default(0)
  likes     Int     @default(0)
  dislikes  Int     @default(0)
  flags     Int     @default(0)
  tag       Tag     @relation(fields: [TagId], references: [id])
  analogy   Analogy @relation(fields: [AnalogyId], references: [id])
}

model TagRelatorParagraph {
  id          String    @id @default(uuid())
  TagId       String
  ParagraphId String
  views       Int       @default(0)
  usage       Int       @default(0)
  likes       Int       @default(0)
  dislikes    Int       @default(0)
  flags       Int       @default(0)
  tag         Tag       @relation(fields: [TagId], references: [id])
  paragraph   Paragraph @relation(fields: [ParagraphId], references: [id])
}

model TagRelatorSummery {
  id        String  @id @default(uuid())
  TagId     String
  SummeryId String
  views     Int     @default(0)
  usage     Int     @default(0)
  likes     Int     @default(0)
  dislikes  Int     @default(0)
  flags     Int     @default(0)
  tag       Tag     @relation(fields: [TagId], references: [id])
  summery   Summery @relation(fields: [SummeryId], references: [id])
}

model TagRelatorKeyWords {
  id         String   @id @default(uuid())
  TagId      String
  KeyWordsId String
  views      Int      @default(0)
  usage      Int      @default(0)
  likes      Int      @default(0)
  dislikes   Int      @default(0)
  flags      Int      @default(0)
  tag        Tag      @relation(fields: [TagId], references: [id])
  keywords   KeyWords @relation(fields: [KeyWordsId], references: [id])
}

model TagRelatorNote {
  id      String @id @default(uuid())
  TagId   String
  NoteId  String
  views   Int    @default(0)
  usage   Int    @default(0)
  likes   Int    @default(0)
  dislikes Int    @default(0)
  flags   Int    @default(0)
  tag     Tag    @relation(fields: [TagId], references: [id])
  note    Note   @relation(fields: [NoteId], references: [id])
}

// --- DEFAULTS ---

model DefaultAnalogy {
  id               String   @id @default(uuid())
  UserId           String
  AnalogyId        String   @unique
  RealParagraphId  String?
  lessonId         String?
  order            Int
  user             User     @relation(fields: [UserId], references: [id])
  
  activeInDefault  Analogy  @relation("ActiveAnalogy", fields: [AnalogyId], references: [id])
  alternatives     Analogy[] @relation("AnalogyPool")
}

model DefaultParagraph {
  id               String   @id @default(uuid())
  UserId           String
  ParagraphId      String   @unique
  RealParagraphId  String
  LessonId         String
  order            Int
  user             User     @relation(fields: [UserId], references: [id])
  
  activeInDefault  Paragraph @relation("ActiveParagraph", fields: [ParagraphId], references: [id])
  alternatives     Paragraph[] @relation("ParagraphPool")
}

model DefaultSummery {
  id               String   @id @default(uuid())
  UserId           String
  SummeryId        String   @unique
  LessonId         String?
  UnitId           String?
  order            Int
  user             User     @relation(fields: [UserId], references: [id])
  
  activeInDefault  Summery  @relation("ActiveSummery", fields: [SummeryId], references: [id])
  alternatives     Summery[] @relation("SummeryPool")
}

model KeyWordDefault {
  id                String   @id @default(uuid())
  UserId            String
  KeyWordsId        String   @unique
  lessonId          String?
  RealParagraphId   String?
  order             Int
  user              User     @relation(fields: [UserId], references: [id])
  
  activeInDefault   KeyWords @relation("ActiveKeywords", fields: [KeyWordsId], references: [id])
  alternatives      KeyWords[] @relation("KeywordsPool")
}

model NoteDefault {
  id               String   @id @default(uuid())
  UserId           String
  NoteId           String   @unique
  LessonId         String
  UnitId           String
  order            Int
  user             User     @relation(fields: [UserId], references: [id])
  
  activeInDefault  Note     @relation("ActiveNote", fields: [NoteId], references: [id])
  alternatives     Note[]   @relation("NotePool")
}

// --- USER ACTIONS ---

model UserAnalogy {
  id        String       @id @default(uuid())
  UserId    String
  AnalogyId String
  status    ActionStatus @default(neutral)
  flaged    Boolean      @default(false)
  skiped    Boolean      @default(false)
  onuse     Boolean      @default(false)
  lastSeenAt DateTime    @default(now())
  user      User         @relation(fields: [UserId], references: [id])
  analogy   Analogy      @relation(fields: [AnalogyId], references: [id])
}

model UserParagraph {
  id          String       @id @default(uuid())
  UserId      String
  ParagraphId String
  status      ActionStatus @default(neutral)
  flaged      Boolean      @default(false)
  skiped      Boolean      @default(false)
  onuse       Boolean      @default(false)
  lastSeenAt  DateTime     @default(now())
  user        User         @relation(fields: [UserId], references: [id])
  paragraph   Paragraph    @relation(fields: [ParagraphId], references: [id])
}

model UserSummery {
  id        String       @id @default(uuid())
  UserId    String
  SummeryId String
  status    ActionStatus @default(neutral)
  flaged    Boolean      @default(false)
  skiped    Boolean      @default(false)
  onuse     Boolean      @default(false)
  lastSeenAt DateTime    @default(now())
  user      User         @relation(fields: [UserId], references: [id])
  summery   Summery      @relation(fields: [SummeryId], references: [id])
}

model UserKeyWords {
  id         String       @id @default(uuid())
  UserId     String
  KeyWordsId String
  status     ActionStatus @default(neutral)
  flaged     Boolean      @default(false)
  skiped     Boolean      @default(false)
  onuse      Boolean      @default(false)
  lastSeenAt DateTime     @default(now())
  user       User         @relation(fields: [UserId], references: [id])
  keywords   KeyWords     @relation(fields: [KeyWordsId], references: [id])
}

model UserNote {
  id      String       @id @default(uuid())
  UserId  String
  NoteId  String
  status  ActionStatus @default(neutral)
  flaged  Boolean      @default(false)
  skiped  Boolean      @default(false)
  onuse   Boolean      @default(false)
  lastSeenAt DateTime   @default(now())
  user    User         @relation(fields: [UserId], references: [id])
  note    Note         @relation(fields: [NoteId], references: [id])
}